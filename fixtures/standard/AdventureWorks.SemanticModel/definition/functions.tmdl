/// @Width {DOUBLE} Width of the SVG viewport in pixels
/// @Height {DOUBLE} Height of the SVG viewport in pixels
/// @IsVisible {BOOLEAN} Toggle for visibility
/// @HtmlContent {STRING} The raw HTML text or markup
/// @CssContent {STRING} Optional custom CSS string
/// @returns SVG data URI string for use in Image visual
function 'EdwardCharles.NativeHTML.HTMLimage' =
	(
		Width : DOUBLE,
		Height : DOUBLE,
		IsVisible : BOOLEAN,
		HtmlContent : STRING,
		CssContent : STRING
	) =>
	var DefaultCss =
		"
			font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
			display: flex;
			justify-content: center;
			padding: 50px;
			margin: 0;
		"

	var TotalCss =
		IF(
			CssContent = "", DefaultCss, CssContent
		)

	var SafeHtml =
		SUBSTITUTE(
			SUBSTITUTE( HtmlContent, "<br>", "<br/>" ),
			"<hr>", "<hr/>"
		)

	var VisibilityRule = IF( IsVisible, "", "visibility:hidden;" )

	VAR SvgOutput =
		"data:image/svg+xml;utf8," &
		"<svg xmlns='http://www.w3.org/2000/svg' width='" & Width & "' height='" & Height & "'>" &
		"  <foreignObject width='100%' height='100%'>" &
		"    <div xmlns='http://www.w3.org/1999/xhtml' style=""" & VisibilityRule & " " & TotalCss & """>" &
				SafeHtml &
		"    </div>" &
		"  </foreignObject>" &
		"</svg>"

	RETURN SvgOutput
annotation DAXLIB_PackageId = NativeHTML
annotation DAXLIB_PackageVersion = 1.0.0
