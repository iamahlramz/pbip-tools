{
  "name": "@pbip-tools/fabric-client",
  "version": "0.1.0",
  "description": "Fabric / Power BI REST client with scope-parameterized auth, per-scope token cache, and redacting error wrapper",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@pbip-tools/core": "0.3.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iamahlramz/pbip-tools.git",
    "directory": "packages/fabric-client"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "power-bi",
    "fabric",
    "pbip",
    "rest-client",
    "auth"
  ],
  "license": "MIT"
}
